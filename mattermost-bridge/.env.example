# Mattermost bridge configuration (copy to .env and fill in).
# The bot must be a MEMBER of the maintenance channel (works with PRIVATE channels).

MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_BOT_TOKEN=your-bot-access-token
MATTERMOST_MAINTENANCE_CHANNEL_ID=26-char-channel-id

# Your deployed EZPM app's inbound endpoint.
APP_WEBHOOK_URL=https://app.example.com/api/webhooks/mattermost

# Shared secret — MUST equal MATTERMOST_OUTGOING_TOKEN set on the EZPM app.
# Any non-empty random string (e.g. `openssl rand -hex 24`).
MATTERMOST_OUTGOING_TOKEN=shared-secret-matching-the-app

# Optional: comma-separated usernames whose posts (and replies mentioning them)
# are kept internal and never mirrored to the tenant (e.g. an AI assistant).
IGNORE_USERNAMES=matter-bot

# Optional: override the reaction endpoint. Defaults to APP_WEBHOOK_URL with
# /mattermost replaced by /mattermost-reaction.
# APP_REACTION_URL=https://app.example.com/api/webhooks/mattermost-reaction

# Optional: port for the /healthz liveness endpoint (default 8080).
# HEALTH_PORT=8080
